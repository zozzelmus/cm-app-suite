{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Aspire AppHost (full stack)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-apphost",
      "program": "${workspaceFolder}/apps/AppHost/bin/Debug/net10.0/Conduct.AppHost.dll",
      "args": [],
      "cwd": "${workspaceFolder}/apps/AppHost",
      "stopAtEntry": false,
      "console": "internalConsole",
      "env": {
        "DOTNET_ENVIRONMENT": "Development",
        "ASPIRE_ALLOW_UNSECURED_TRANSPORT": "true"
      }
    },
    {
      "name": "Web standalone (Vite, no Aspire — assumes BFF already running)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "cwd": "${workspaceFolder}/apps/web",
      "console": "integratedTerminal"
    },
    {
      "name": "Web tests (vitest)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["test:watch"],
      "cwd": "${workspaceFolder}/apps/web",
      "console": "integratedTerminal"
    }
  ]
}
