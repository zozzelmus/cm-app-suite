{
  "realm": "conduct",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "sslRequired": "external",
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 28800,
  "clientScopes": [
    {
      "name": "conduct:use",
      "description": "Entry-level access to the Conduct application",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false",
        "consent.screen.text": ""
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "conduct:admin-panel",
      "description": "Access to the Conduct admin panel (LOB/CaseType/Role config)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false",
        "consent.screen.text": ""
      }
    },
    {
      "name": "conduct:audit-export",
      "description": "Permission to export regulator-formatted audit dumps",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false",
        "consent.screen.text": ""
      }
    }
  ],
  "clients": [
    {
      "clientId": "conduct-bff",
      "name": "Conduct BFF (server-side, confidential)",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "secret": "dev-secret",
      "rootUrl": "http://localhost:5010",
      "redirectUris": [
        "http://localhost:*/signin-oidc",
        "https://localhost:*/signin-oidc"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:*##https://localhost:*",
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["openid", "profile", "email", "conduct:use"],
      "optionalClientScopes": ["conduct:admin-panel", "conduct:audit-export"]
    }
  ],
  "users": [
    {
      "id": "00000000-0000-0000-0000-000000000010",
      "username": "demo",
      "enabled": true,
      "email": "demo@conduct.local",
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "attributes": {
        "tenant_id": ["00000000-0000-0000-0000-000000000001"]
      },
      "credentials": [{ "type": "password", "value": "demo", "temporary": false }]
    }
  ]
}
